{
  "name": "ride-platform",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web-home --filter web-admin --parallel dev",
    "dev:home": "pnpm --filter web-home dev",
    "dev:admin": "pnpm --filter web-admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
