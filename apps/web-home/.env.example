# 카카오맵 (오시는길 페이지) - JavaScript 키
# https://developers.kakao.com/console/app → 앱 키 → JavaScript 키
# 플랫폼에 Web 추가 후 localhost 및 배포 도메인 등록 필요
NEXT_PUBLIC_KAKAO_MAP_KEY=

# API — 공지(서버 fetch)·문의(브라우저) 등.
# - 반드시 http(s) 절대 URL. 상대 경로 `/api/v1` 만 넣지 말 것(web-home에 리라이트 없음).
# - Vercel에서 NEXT_PUBLIC 빌드 타이밍 이슈가 있으면 서버 전용으로 아래 중 하나 추가 후 재배포:
#   RIDE_API_BASE_URL=https://백엔드호스트/api/v1
#   API_SERVER_BASE_URL=https://백엔드호스트/api/v1
# 백엔드: GET /api/v1/notices?limit=50 와 GET /notices?limit=50
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5174/api/v1
