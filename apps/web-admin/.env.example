# 백엔드 API (Flutter 앱과 동일한 base)
# Base URL에 /api/v1 포함
# 관리자 인증: httpOnly 세션 쿠키 + fetch credentials:include (BACKEND_COOKIE_AUTH.md 참고)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5174/api/v1

# 개발 전용: API URL 없이 모의 로그인/가입 (운영 빌드에서는 무시됨)
# NEXT_PUBLIC_ALLOW_MOCK_AUTH=true

# 개발에서도 회원가입 페이지 숨김·차단 (운영에서는 항상 비활성)
# NEXT_PUBLIC_DISABLE_ADMIN_SIGNUP=true
