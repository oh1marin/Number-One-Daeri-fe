# 백엔드 API (Flutter 앱과 동일한 base)
# Base URL에 /api/v1 포함
# 관리자 인증: httpOnly 세션 쿠키 + fetch credentials:include (BACKEND_COOKIE_AUTH.md 참고)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5174/api/v1

# 개발 전용: API URL 없이 모의 로그인/가입 (운영 빌드에서는 무시됨)
# NEXT_PUBLIC_ALLOW_MOCK_AUTH=true

# 개발에서도 회원가입 페이지 숨김·차단 (운영에서는 항상 비활성)
# NEXT_PUBLIC_DISABLE_ADMIN_SIGNUP=true

# ── 관리자 보안 (middleware + 로그인 Rate limit) ─────────────────────────────
# httpOnly 세션 쿠키 이름 (BE Set-Cookie 와 일치). 콤마 구분. 미설정 시 ride_admin_at/rt 사용
# 로그인 응답 예: ride_admin_at (1h), ride_admin_rt (7d), Path=/api/v1/admin, SameSite=None
ADMIN_SESSION_COOKIE_NAMES=ride_admin_at,ride_admin_rt
# middleware 쿠키 인증 (BE 쿠키 Path=/api/v1/admin 이면 www 에 쿠키 없어 기본 off)
# ADMIN_MIDDLEWARE_AUTH=true
#
# 로그인을 Next 같은 출처로 보내 Rate limit 적용 (운영 권장)
# ADMIN_API_UPSTREAM=https://api.example.com  (next.config rewrite 와 동일)
# NEXT_PUBLIC_USE_ADMIN_AUTH_PROXY=true
#
# Upstash Redis (없으면 Rate limit 미적용)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=10
# ADMIN_LOGIN_RATE_LIMIT_WINDOW_SEC=60
#
# Cloudflare Rate limiting (Upstash 대안·병행) — 규칙 URI Path:
#   · 관리자 사이트 GET  /login
#   · 프록시 사용 시 POST /api/auth/login
#   · rewrite 사용 시 POST /api/v1/admin/auth/login
# 로그인 API를 API 도메인에 직접 두면(프록시 미사용) API 호스트에:
#   POST /api/v1/admin/auth/login

# ── 기프티쇼 비즈 (SERVER TO SERVER) ─────────────────────────────────────────
# 엔드포인트 예: https://biz.giftishow.com/orderSend/apimain
# 통신: UTF-8, Accept application/json, 타임아웃 30초 권장
# 연동은 백엔드에서만 수행 (FE .env는 로컬 테스트·문서용)
#
# 필수 HTTP Header (모든 호출):
#   custom_auth_code  — 인증 Key (서비스 관리 메뉴)
#   custom_auth_token — 인증 Key를 암호화 키로 AES256/ECB/PKCS5Padding 후 Base64
#   api_code          — API 번호 (예: 공통 코드 리스트 0001)
#   dev_flag          — 개발 Y / 상용 N
#
# 개발 환경: 테스트 상품코드 2종, 비즈머니 차감 없음, MMS 카드/배너 이미지 각 1개
GIFTISHOW_API_URL=https://biz.giftishow.com/orderSend/apimain
GIFTISHOW_AUTH_KEY=
# 담당자 전달 암호화 키 (Token Key) — custom_auth_token 생성에 사용
GIFTISHOW_ENCRYPT_KEY=
# 이미 발급된 custom_auth_token 이 있으면 여기에 넣고 ENCRYPT_KEY 생략 가능
# GIFTISHOW_AUTH_TOKEN=
GIFTISHOW_DEV_FLAG=Y
# 테스트용 api_code (규격서 수령 후 변경)
GIFTISHOW_TEST_API_CODE=0001
GIFTISHOW_TIMEOUT_MS=30000
# 개발 테스트 상품코드 (배너/카드 각 1종)
GIFTISHOW_BANNER_GOODS_ID=
GIFTISHOW_CARD_GOODS_ID=
